{
  "name": "altus-ai",
  "version": "3.0.30",
  "description": "Microsoft Windows Accessibility Bridge - Diagnostic Framework",
  "author": "Microsoft System Framework",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "electron:dev": "npm run build:electron && cross-env NODE_ENV=development electron .",
    "app:dev": "concurrently \"npm run dev -- --port 5173 --strictPort\" \"wait-on http://localhost:5173 && npm run electron:dev\"",
    "app:build": "npm run build && npm run build:electron && electron-builder",
    "start": "npm run app:dev",
    "dist": "npm run app:build"
  },
  "build": {
    "appId": "com.microsoft.windows.accessibility-bridge",
    "productName": "WinDiagnostic_Accessibility_Service",
    "files": [
      "dist",
      "dist-electron",
      "assets",
      "package.json"
    ],
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "requestedExecutionLevel": "highestAvailable",
      "certificateFile": "assets/Altus_Accessibility.pfx",
      "certificatePassword": "altusplatinum",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Altus AI",
      "artifactName": "Altus-AI-Platinum-Setup-v${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Hey-Astreon",
        "repo": "Altus-Ai-Platinum"
      }
    ]
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "axios": "^1.7.7",
    "dotenv": "^17.4.2",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.460.0",
    "mermaid": "^11.14.0",
    "openai": "^4.73.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "screenshot-desktop": "^1.15.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  }
}
